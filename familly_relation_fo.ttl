#
# Prefixes
#
@prefix az: <https://w3id.org/people/az/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix fo: <http://purl.org/family/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#
# Ontology definition and metadata
#
fo: a owl:Ontology;
    rdfs:label "The family ontology"@en;
    rdfs:comment "An ontology for family relationships."@en;
    dct:title "The Family Ontology"@en;
    dct:created "2023-11-19T14:42:42+01:00"^^xsd:dateTime;
    dct:modified "2026-01-23T13:42:42+01:00"^^xsd:dateTime;
    dct:creator az:me .

#
# Classes
#
fo:Male a owl:Class;
        rdfs:label "male"@en;
        rdfs:comment "A male individual. The gender may be a â€œnaturalâ€ one, attributed at birth, or a given one by social conventions."@en .

fo:Female a owl:Class;
          rdfs:label "female"@en;
          rdfs:comment "A female individual. The gender may be a â€œnaturalâ€ one, attributed at birth, or a given one by social conventions."@en .


#
# Object properties
#
fo:isADescendentOf a owl:ObjectProperty, owl:TransitiveProperty;
                   rdfs:label "is a descendent of"@en;
                   rdfs:comment "A relation between someone and one of their ancestors."@en .

fo:isAnAncestorOf a owl:ObjectProperty, owl:TransitiveProperty;
                  owl:inverseOf fo:isADescendentOf;
                  rdfs:label "is an ancestor of"@en;
                  rdfs:comment "A relation between someone and one their of descendants."@en .

fo:isAChildOf a owl:ObjectProperty;
              rdfs:subPropertyOf fo:isADescendentOf;
              owl:inverseOf fo:isAParentOf;
              rdfs:label "is a child of"@en;
              rdfs:comment "A relation between someone and their parent"@en .

fo:isAParentOf a owl:ObjectProperty;
               rdfs:subPropertyOf fo:isAnAncestorOf;
               owl:inverseOf fo:isAChildOf;
               rdfs:label "is a parent of"@en;
               rdfs:comment "A relation between a parent and their child"@en .

fo:isASonOf a owl:ObjectProperty;
            rdfs:subPropertyOf fo:isTheChildOf;
            rdfs:domain fo:Male;
            rdfs:label "is a son of"@en;
            rdfs:comment "A relation between a male child and his parent."@en .

fo:isADaughterOf a owl:ObjectProperty;
                 rdfs:subPropertyOf fo:isTheChildOf;
                 rdfs:domain fo:Female;
                 rdfs:label "is a daughter of"@en;
                 rdfs:comment "A relation between a female child and his parent."@en .

fo:isTheFatherOf a owl:ObjectProperty;
                 rdfs:subPropertyOf fo:isAParentOf;
                 rdfs:domain fo:Male;
                 rdfs:label "is the father of"@en;
                 rdfs:comment "A relation between a father and his child."@en .

fo:isTheMotherOf a owl:ObjectProperty;
                 rdfs:subPropertyOf fo:isAParentOf;
                 rdfs:domain fo:Female;
                 rdfs:label "is the mother of"@en;
                 rdfs:comment "A relation between a mother and his child."@en .

fo:isASibingOf a owl:ObjectProperty, owl:SymmetricProperty;
               rdfs:label "is a sibling of"@en;
               rdfs:comment "Two individuals who share the same parent."@en .

fo:isABrotherOf a owl:ObjectProperty;
                rdfs:subPropertyOf fo:isASiblingOf;
                rdfs:domain fo:Male;
                rdfs:label "is a brother of"@en;
                rdfs:comment "A male sibling of someone."@en .

fo:isASisterOf a owl:ObjectProperty;
               rdfs:subPropertyOf fo:isASiblingOf;
               rdfs:domain fo:Female;
               rdfs:label "is a sister of"@en;
               rdfs:comment "A female sibling of someone."@en .

fo:isACousinOf a owl:ObjectProperty, owl:SymmetricProperty;
               owl:propertyChainAxiom (fo:isAChildOf fo:isASiblingOf fo:isAParentOf);
               rdfs:label "is a cousin of"@en;
               rdfs:comment "One that is the child of a sibling of the parent of someone else."@en .

fo:isMarriedTo a owl:ObjectProperty, owl:SymmetricProperty;
               rdfs:label "is married to"@en;
               rdfs:comment "People united through marriage."@en .