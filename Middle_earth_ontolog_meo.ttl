#
# Prefixes
#
@prefix az: <https://w3id.org/people/az/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix fo: <http://purl.org/family/> .
@prefix meo: <http://purl.org/meo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

#
# Ontology definition and metadata
#
meo: a owl:Ontology;
     owl:imports fo:;
     rdfs:label "The Middle-earth ontology"@en;
     rdfs:comment "An ontology for J.R.R. TolkienÊ¼s legendarium."@en;
     dct:title "The Middle-earth ontology"@en;
     dct:created "2023-11-19T07:42:42+01:00"^^xsd:dateTime;
     dct:creator az:me .

#
# Classes
#
meo:God a owl:Class;
        owl:oneOf (meo:Eru);
        rdfs:label "God"@en;
        rdfs:comment "A sperior entity. A singleton class that only contains Eru IlÃºvatar, the One Allfather."@en .

meo:Immortal a owl:Class;
             owl:disjointWith meo:Mortal;
             rdfs:label "immortal"@en;
             rdfs:comment "An individual that does not die of natural death. Some immortals may die from wounds inflicted to them by violence or accident (like Elves), but some are truly eternal, like the Ainur)."@en .

meo:Mortal a owl:Class;
           owl:disjointWith meo:Immortal;
           rdfs:label "mortal"@en;
           rdfs:comment "Mortal living being, such as Men and Dwarces."@en .

meo:EvilBeing a owl:Class;
              rdfs:label "evil being"@en;
              rdfs:comment "The evil beings are sentient agents that have chosen to do bad things, behave badly for the sake of doing bad, or became corrupted into doing evil. Some things are raised and bred to be evil. Some things are led to become evil by other evil beings by subversion. Some choose to become evil due to greed or as a way to overcome hardships of their lives."@en .

meo:Ainu a owl:Class;
         rdfs:subClassOf meo:Immortal;
         rdfs:label "Ainu"@qya, "Holy one"@en;
         rdfs:comment "The Ainur (plural form of Ainu) are the spirits created by Eru IlÃºvatar before time existed"@en .

meo:Vala a owl:Class;
         rdfs:subClassOf meo:Ainu;
         rdfs:label "Vala"@qya, "angelic power"@en;
         rdfs:comment "The Valar (plural form of Vala) are the most powerful Ainur who entered Arda, the world."@en .

meo:Maia a owl:Class;
         rdfs:subClassOf meo:Ainu;
         rdfs:label "Maia"@qya, "Beautiful"@en;
         rdfs:comment "The Maiar (plural form of Maia) are Ainur who entered Arda and serve the Valar."@en .

meo:Eruhin a owl:Class;
           rdfs:label "Eruhin"@qya, "Child of IlÃºvatar"@en;
           skos:altLabel "Child of Eru"@en;
           rdfs:comment "The EruhÃ­ni (plural form of Eruhin), literally â€œthe Children of Eruâ€, are usually called the â€œChildren of IlÃºvatarâ€. They are the Elves and Men. â€œChildren of IlÃºvatarâ€ is used to collectively refer to the two races of Men and Elves, and the singular form is rarely used."@en .

meo:QuendÃ« a owl:Class;
           rdfs:subClassOf meo:Eruhin, meo:Immortal;
           rdfs:label "QuendÃ«"@qya, "Elf"@en;
           skos:altLabel "one that speaks"@en, "Firstborn"@en, "Elda"@qya;
           rdfs:comment "The Quendi (plural form of QuendÃ«) are the first born of the Children of IlÃºvatar, the Elves. They are named thus because they were the only ones who spoke when they first appeared, before Men and Dwarves came to be. They are more often called the Eldar."@en .

meo:Elda a owl:Class;
         owl:equivalentTo meo:QuendÃ«;
         rdfs:label "Elda"@qya, "Eledh"@sjn, "Elf"@en;
         skos:altLabel "of the stars"@en, "person of the stars"@en, "Firstborn"@en;
         rdfs:comment "The Eldar (plural form of Elda) are the Elves. They initially called themselves the Quendi, but the Vala OromÃ«, who met them at lake CuiviÃ©nen under the stars, called them the Eldar. Now only the Quendi who followed OromÃ« to the West call themselves Eldar."@en .

meo:Atan a owl:Class;
         rdfs:label "Atan"@qya, "Adan"@sjn, "Man"@en;
         skos:altLabel "Secondborn"@en, "Hildo"@qya, "Follower"@en, "After-comer"@en, "ApanÃ³na"@qya, "After-born"@en, "Engwa"@qya, "Sickly"@en, "FÃ­rima"@qya, "Mortal"@en, "Human"@en; 
         rdfs:comment "The Atani (plural form of Atan) are the second born of the Children of IlÃºvatar, the Men (i.e. Humans, not male people). They were given many names also by the Eldar."@en .

meo:Adan a owl:Class;
         owl:subClassOf meo:Atan;
         rdfs:label "Adan"@sjn, "Man"@en;
         rdfs:comment "The Edain (plural form of Adan) are the Men that belong to the Three Houses of Men that came to Beleriand in the elder days. Originally, â€œAdanâ€ (plural â€œEdainâ€) is the Sindarin equivalent of Quenya â€œAtanâ€ (plural â€œAtaniâ€) but eventually came to mean this narrow subgroup."@en .

meo:Peredhel a owl:Class;
             owl:subClassOf meo:Eruhin, [
                a owl:Restriction;
                owl:onProperty fo:isDescendentOf;
                owl:someValuesFrom meo:Atan;
             ], [
                a owl:Restriction;
                owl:onProperty fo:isDescendentOf;
                owl:someValuesFrom meo:Elda;
             ];
             rdfs:label "Peredhel"@sjn, "Half-elf"@en;
    	     rdfs:comment "Peredhil are descendent of both elves and humans."@en .
    
meo:Casar a owl:Class;
          owl:subClassOf meo:Mortal;
          rdfs:label "Casar"@qya, "Naug"@sjn, "Dwarf"@en;
          skos:altLabel "AulÃ«onna"@qya, "Child of AulÃ«"@en;
          rdfs:comment "The Casari (plural form of Casar in Quenya), more often called with the Sindarin variant Naugrim (plural of Naug in Sindarin), are the Dwarves created by the Vala AulÃ«."@en .

meo:Torog a owl:Class;
          rdfs:subClassOf meo:EvilBeing;
          rdfs:label "torog"@sjn, "troll"@en;
          rdfs:comment "The *Teryg (probably the plural form of Torog in Sindarin) are the Trolls, large humanoid monsters of great physical strength and weak intellect."@en .

meo:LÃ³cÃ« a owl:Class;
         rdfs:subClassOf meo:EvilBeing;
         rdfs:label "LÃ³cÃ«"@qya, "Dragon"@en;
         rdfs:comment "Evil and powerful monster."@en .


#
# Object properties
#
meo:served a owl:ObjectProperty;
           rdfs:label "serves"@en;
           rdfs:comment "Relates someone to someone else that they serve. Relation servant-master."@en .

#
# Individuals
#
meo:eru a meo:God;
        rdfs:label "Eru"@qya, "The One"@en;
        skos:altLabel "IlÃºvatar"@qya, "Eru IlÃºvatar"@qya, "God"@en, "The Allfather"@en;
        rdfs:comment "The one God creator of everything."@en .

meo:melkor a meo:Vala;
           rdfs:label "Melkor"@qya, "He who arises in might"@en;
           rdfs:comment "The greatest of the Ainur."@en .

meo:morgoth a meo:EvilBeing;
            owl:sameAs meo:melkor;
            rdfs:label "Morgoth"@sjn, "The Black Enemy"@en;
            skos:altLabel "Bauglir"@sjn, "The Constrainer"@en;
            rdfs:comment "The only Vala who became evil. The enemy of all other Valar."@en .

#
# Axioms
#
# Whoever serves Morgoth is evil
[
    a owl:Restriction;
    owl:onProperty meo:serves;
    owl:hasValue meo:morgoth
] rdfs:subClassOf meo:EvilBeing .

# Those whose parents are all Elves are also Elves
[
    a owl:Restriction;
    owl:onProperty fo:isAChildOf;
    owl:allValuesFrom meo:Elda
] rdfs:subClassOf meo:Elda .

# Those whose parents are all Men (i.e., humans) are also Men (i.e., humans)
[
    a owl:Restriction;
    owl:onProperty fo:isAChildOf;
    owl:allValuesFrom meo:Atan
] rdfs:subClassOf meo:Atan .

# Those who have an Elvish parent and a Human parent are Half-elven
[
    a owl:Class;
    owl:intersectionOf ([
        a owl:Restriction;
        owl:onProperty fo:isAChildOf;
        owl:someValuesFrom meo:Elda
    ] [
        a owl:Restriction;
        owl:onProperty fo:isAChildOf;
        owl:someValuesFrom meo:Adan
    ])
] rdfs:subClassOf meo:Peredhel .

# Those whose father and mother are both of the Man race, are also Men
[
    owl:intersectionOf ([
        a owl:Restriction;
        owl:onProperty [owl:inversOf fo:isTheFatherOf];
        owl:someValuesFrom meo:Atan
    ] [
        a owl:Restriction;
        owl:onProperty [owl:inversOf fo:isTheMotherOf];
        owl:someValuesFrom meo:Atan
    ])
] rdfs:subClassOf meo:Atan .

# Those whose father and mother are both of the Elf race, are also Elves
[
    owl:intersectionOf ([
        a owl:Restriction;
        owl:onProperty [owl:inversOf fo:isTheFatherOf];
        owl:someValuesFrom meo:Elda
    ] [
        a owl:Restriction;
        owl:onProperty [owl:inversOf fo:isTheMotherOf];
        owl:someValuesFrom meo:Elda
    ])
] rdfs:subClassOf meo:Elda .