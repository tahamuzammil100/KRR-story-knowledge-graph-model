@prefix : <http://purl.org/narn/> .
@prefix fo: <http://purl.org/family/> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix loc: <http://purl.org/narn/social/> .
@prefix meo: <http://purl.org/meo/> .
@prefix nac: <http://purl.org/narn/action/> .
@prefix nev: <http://purl.org/narn/event/> .
@prefix npl: <http://purl.org/narn/plot/> .
@prefix npo: <http://purl.org/narn/place/> .
@prefix nti: <http://purl.org/narn/time/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix narn: <http://purl.org/narn/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://purl.org/narn/> .

<http://purl.org/narn/> rdf:type owl:Ontology ;
                         owl:imports nac: ,
                                     nev: ,
                                     npl: ,
                                     loc: ;
                         dct:created "2026-04-03T10:00:00+01:00"^^xsd:dateTime ;
                         dct:title "Narn i Chîn Húrin Instances"@en ;
                         rdfs:comment "Concrete instances from the Narn i Chîn Húrin (Tale of the Children of Húrin) illustrating all ontology modules."@en ;
                         rdfs:label "Narn i Chîn Húrin — instances"@en .

#################################################################
#    Individuals
#################################################################

###  http://purl.org/meo/morgoth
meo:morgoth loc:isEnemyOf narn:hurin .


###  http://purl.org/narn/angband
narn:angband rdf:type owl:NamedIndividual ,
                      npo:Fortress ;
             npo:isDisconnectedFrom narn:brethil ,
                                    narn:doriath ,
                                    narn:nargothrond ;
             rdfs:comment "The mighty fortress of Morgoth in the far north. Prison of Húrin."@en ;
             rdfs:label "Angband"@en ,
                        "Hell of Iron"@en .


###  http://purl.org/narn/arcHurin
narn:arcHurin rdf:type owl:NamedIndividual ,
                       npl:PlotArc ;
              npl:beginsWithEvent narn:nirnaeth ;
              npl:endsWithEvent narn:hurinCapture ;
              rdfs:label "Arc of Húrin's captivity"@en .


###  http://purl.org/narn/arcTurin
narn:arcTurin rdf:type owl:NamedIndividual ,
                       npl:PlotArc ;
              npl:beginsWithEvent narn:turinArrivalDoriath ;
              npl:endsWithEvent narn:turinDeath ;
              npl:hasPlotPoint narn:climaxNarn ,
                               narn:expNarn ,
                               narn:fallingNarn ,
                               narn:resolutionNarn ,
                               narn:risingNarn ;
              rdfs:label "Arc of Túrin Turambar"@en .


###  http://purl.org/narn/beleg
narn:beleg rdf:type owl:NamedIndividual ,
                    fo:Male ,
                    meo:Elda ;
           loc:isFriendOf narn:turin ;
           loc:isMentorOf narn:turin ;
           rdfs:comment "Greatest archer of Doriath. Close companion and mentor figure to Túrin."@en ;
           rdfs:label "Beleg"@en ,
                      "Beleg Cúthalion"@en .


###  http://purl.org/narn/belegDeath
narn:belegDeath rdf:type owl:NamedIndividual ,
                         nev:Death ;
                nev:hasAgent narn:turin ;
                nev:hasSubject narn:beleg ;
                nev:hasTemporalExtent narn:tirTurinExile ;
                nev:occursAt narn:dimbar ;
                nev:precedes narn:fallOfNargothrond ;
                rdfs:comment "Túrin, confused and half-mad after rescue, kills his companion Beleg by accident."@en ;
                rdfs:label "Death of Beleg"@en .


###  http://purl.org/narn/beleriand
narn:beleriand rdf:type owl:NamedIndividual ,
                        npo:GeographicRegion ;
               rdfs:comment "The great land in the north-west of Middle-earth during the First Age."@en ;
               rdfs:label "Beleriand"@en .


###  http://purl.org/narn/brandir
narn:brandir rdf:type owl:NamedIndividual ,
                      fo:Male ,
                      meo:Adan ;
             rdfs:comment "Chieftain of the Haladin in Brethil. Lame and peaceable. Loved Nienor."@en ;
             rdfs:label "Brandir"@en .


###  http://purl.org/narn/brethil
narn:brethil rdf:type owl:NamedIndividual ,
                      npo:Forest ;
             npo:borders narn:doriath ;
             npo:isLocatedIn narn:beleriand ;
             rdfs:comment "The forest between Doriath and Nargothrond, home of the Haladin. Túrin's last refuge."@en ;
             rdfs:label "Brethil"@en .


###  http://purl.org/narn/climaxNarn
narn:climaxNarn rdf:type owl:NamedIndividual ,
                         npl:Climax ;
                npl:correspondsToEvent narn:fallOfNargothrond ;
                npl:precedes narn:fallingNarn ;
                rdfs:label "Climax: Fall of Nargothrond"@en .


###  http://purl.org/narn/dimbar
narn:dimbar rdf:type owl:NamedIndividual ,
                     npo:WildArea ;
            npo:borders narn:doriath ;
            npo:isLocatedIn narn:beleriand ;
            rdfs:comment "The desolate land between the rivers Sirion and Mindeb, north of Doriath."@en ;
            rdfs:label "Dimbar"@en .


###  http://purl.org/narn/dorLomin
narn:dorLomin rdf:type owl:NamedIndividual ,
                       npo:GeographicRegion ;
              npo:isLocatedIn narn:beleriand ;
              rdfs:comment "The homeland of Húrin, a fief of Hithlum. Given by Morgoth to the Easterlings after Nirnaeth."@en ;
              rdfs:label "Dor-lómin"@en .


###  http://purl.org/narn/doriath
narn:doriath rdf:type owl:NamedIndividual ,
                      npo:GeographicRegion ;
             npo:isLocatedIn narn:beleriand ;
             rdfs:comment "The hidden kingdom of Thingol and Melian, protected by the Girdle of Melian."@en ;
             rdfs:label "Doriath"@en .


###  http://purl.org/narn/expNarn
narn:expNarn rdf:type owl:NamedIndividual ,
                      npl:Exposition ;
             npl:correspondsToEvent narn:nirnaeth ;
             npl:precedes narn:risingNarn ;
             rdfs:label "Exposition: Húrin and the Nirnaeth"@en .


###  http://purl.org/narn/fallOfNargothrond
narn:fallOfNargothrond rdf:type owl:NamedIndividual ,
                                nev:Battle ;
                       nev:causedBy narn:morgothCurse ;
                       nev:hasTemporalExtent narn:tirFallNargothrond ;
                       nev:involvesCharacter meo:morgoth ,
                                             narn:finduilas ,
                                             narn:glaurung ,
                                             narn:turin ;
                       nev:occursAt narn:nargothrond ;
                       nev:precedes narn:finduilasDeath ,
                                    narn:glaurungCurse ;
                       rdfs:comment "Glaurung leads Morgoth's forces to destroy Nargothrond. Finduilas is captured and later slain. This is the climax of the story."@en ;
                       rdfs:label "Fall of Nargothrond"@en .


###  http://purl.org/narn/fallingNarn
narn:fallingNarn rdf:type owl:NamedIndividual ,
                          npl:FallingAction ;
                 npl:correspondsToEvent narn:glaurungCurse ;
                 npl:precedes narn:resolutionNarn ;
                 rdfs:label "Falling action: Glaurung's curse on Nienor"@en .


###  http://purl.org/narn/finduilas
narn:finduilas rdf:type owl:NamedIndividual ,
                        fo:Female ,
                        meo:Elda ;
               loc:isMemberOf narn:nargothrondFellowship ;
               rdfs:comment "Elven princess of Nargothrond. Daughter of Orodreth. Loved Túrin but was slain by orcs."@en ;
               rdfs:label "Finduilas"@en .


###  http://purl.org/narn/finduilasDeath
narn:finduilasDeath rdf:type owl:NamedIndividual ,
                             nev:Death ;
                    nev:causedBy narn:fallOfNargothrond ;
                    nev:hasSubject narn:finduilas ;
                    nev:occursAt narn:brethil ;
                    rdfs:comment "Finduilas is slain by orcs on the road after the fall of Nargothrond."@en ;
                    rdfs:label "Death of Finduilas"@en .


###  http://purl.org/narn/glaurung
narn:glaurung rdf:type owl:NamedIndividual ,
                       meo:Lócë ;
              loc:isEnemyOf narn:turin ;
              rdfs:comment "The first and greatest of the dragons, 'Father of Dragons'. Servant of Morgoth. Cursed Túrin and Nienor."@en ;
              rdfs:label "Glaurung"@en .


###  http://purl.org/narn/glaurungCurse
narn:glaurungCurse rdf:type owl:NamedIndividual ,
                            nev:Curse ;
                   nev:causedBy narn:fallOfNargothrond ;
                   nev:hasAgent narn:glaurung ;
                   nev:hasSubject narn:nienor ;
                   nev:occursAt narn:nargothrond ;
                   rdfs:comment "Glaurung meets Nienor at the ford of Nargothrond and strips her memory with his gaze."@en ;
                   rdfs:label "Glaurung's curse on Nienor"@en .


###  http://purl.org/narn/gurthang
narn:gurthang rdf:type owl:NamedIndividual ,
                       nac:Weapon ;
              rdfs:comment "Túrin's cursed black sword, reforged from the broken blade Anglachel."@en ;
              rdfs:label "Gurthang"@en ,
                         "Iron of Death"@en .


###  http://purl.org/narn/houseOfHadorKingdom
narn:houseOfHadorKingdom rdf:type owl:NamedIndividual ,
                                  loc:Kingdom ;
                         rdfs:comment "The noble house of Men to which Húrin and Túrin belong."@en ;
                         rdfs:label "House of Hador"@en .


###  http://purl.org/narn/hurin
narn:hurin rdf:type owl:NamedIndividual ,
                    fo:Male ,
                    meo:Adan ;
           fo:isAParentOf narn:nienor ,
                          narn:turin ;
           fo:isMarriedTo narn:morwen ;
           loc:isEnemyOf meo:morgoth ;
           loc:isMemberOf narn:houseOfHadorKingdom ;
           rdfs:comment "Lord of Dor-lómin, the steadfast. Captured by Morgoth at the Nirnaeth Arnoediad. His family is cursed."@en ;
           rdfs:label "Húrin"@en ,
                      "Húrin Thalion"@en .


###  http://purl.org/narn/hurinCapture
narn:hurinCapture rdf:type owl:NamedIndividual ,
                           nev:Capture ;
                  nev:causedBy narn:nirnaeth ;
                  nev:hasAgent meo:morgoth ;
                  nev:hasSubject narn:hurin ;
                  nev:hasTemporalExtent narn:tirNirnaeth ;
                  nev:occursAt narn:angband ;
                  nev:precedes narn:morgothCurse ;
                  rdfs:comment "Húrin is taken alive by Morgoth after the Nirnaeth, the last to be captured."@en ;
                  rdfs:label "Capture of Húrin"@en .


###  http://purl.org/narn/mablung
narn:mablung rdf:type owl:NamedIndividual ,
                      fo:Male ,
                      meo:Elda ;
             rdfs:comment "Chief captain of Doriath. Accompanied Morwen and Nienor to find Túrin."@en ;
             rdfs:label "Mablung"@en .


###  http://purl.org/narn/melian
narn:melian rdf:type owl:NamedIndividual ,
                     fo:Female ,
                     meo:Maia ;
            fo:isMarriedTo narn:thingol ;
            rdfs:comment "Maia queen of Doriath, wife of Thingol. Her Girdle protected the realm."@en ;
            rdfs:label "Melian"@en .


###  http://purl.org/narn/menegroth
narn:menegroth rdf:type owl:NamedIndividual ,
                        npo:Cavern ,
                        npo:Settlement ;
               npo:isSubpartOf narn:doriath ;
               rdfs:comment "The underground city of Thingol and Melian, capital of Doriath."@en ;
               rdfs:label "Menegroth"@en ,
                          "The Thousand Caves"@en .


###  http://purl.org/narn/morgothCurse
narn:morgothCurse rdf:type owl:NamedIndividual ,
                           nev:Curse ;
                  nev:causedBy narn:hurinCapture ;
                  nev:hasAgent meo:morgoth ;
                  nev:hasSubject narn:nienor ,
                                 narn:turin ;
                  nev:occursAt narn:angband ;
                  nev:precedes narn:turinExile ;
                  rdfs:comment "Morgoth lays a doom of sorrow on the children of Húrin."@en ;
                  rdfs:label "Curse of Morgoth on Húrin's house"@en .


###  http://purl.org/narn/morgothCurseAction
narn:morgothCurseAction rdf:type owl:NamedIndividual ,
                                 nac:CoerciveAction ,
                                 nac:IntentionalAction ,
                                 nac:SpeechAct ;
                        nac:hasAgent meo:morgoth ;
                        nac:hasPatient narn:nienor ,
                                       narn:turin ;
                        nac:hasPurpose narn:morgothCurse ;
                        nac:hasResult narn:morgothCurse ;
                        nev:occursAt narn:angband ;
                        rdfs:comment "Morgoth pronounces the doom on Húrin's family. An intentional speech act with coercive effect."@en ;
                        rdfs:label "Morgoth's curse (speech act)"@en .


###  http://purl.org/narn/morwen
narn:morwen rdf:type owl:NamedIndividual ,
                     fo:Female ,
                     meo:Adan ;
            fo:isAParentOf narn:nienor ,
                           narn:turin ;
            fo:isMarriedTo narn:hurin ;
            loc:isAllyOf narn:beleg ;
            loc:isMemberOf narn:houseOfHadorKingdom ;
            rdfs:comment "Wife of Húrin, mother of Túrin and Nienor. Renowned for her beauty and stern spirit."@en ;
            rdfs:label "Morwen"@en ,
                       "Morwen Eledhwen"@en .


###  http://purl.org/narn/nargothrond
narn:nargothrond rdf:type owl:NamedIndividual ,
                          npo:Cavern ,
                          npo:Fortress ;
                 npo:isLocatedIn narn:beleriand ;
                 rdfs:comment "The great underground fortress on the River Narog, built by Finrod Felagund. Túrin became its de facto ruler."@en ;
                 rdfs:label "Nargothrond"@en .


###  http://purl.org/narn/nargothrondFellowship
narn:nargothrondFellowship rdf:type owl:NamedIndividual ,
                                    loc:Fellowship ;
                           rdfs:comment "The company of warriors and elves dwelling in Nargothrond."@en ;
                           rdfs:label "Fellowship of Nargothrond"@en .


###  http://purl.org/narn/narnStory
narn:narnStory rdf:type owl:NamedIndividual ,
                        npl:Story ,
                        npl:Tragedy ;
               npl:beginsWithEvent narn:nirnaeth ;
               npl:endsWithEvent narn:turinDeath ;
               npl:hasAntagonist meo:morgoth ,
                                 narn:glaurung ;
               npl:hasClimax narn:climaxNarn ;
               npl:hasFatalFlaw narn:morgothCurse ;
               npl:hasPlotArc narn:arcHurin ,
                              narn:arcTurin ;
               npl:hasProtagonist narn:turin ;
               rdfs:comment "The tragedy of Túrin Turambar and his sister Nienor, cursed by Morgoth through their father Húrin."@en ;
               rdfs:label "Narn i Chîn Húrin"@en ,
                          "Tale of the Children of Húrin"@en .


###  http://purl.org/narn/nienor
narn:nienor rdf:type owl:NamedIndividual ,
                     fo:Female ,
                     meo:Adan ;
            fo:isADaughterOf narn:hurin ,
                             narn:morwen ;
            fo:isASiblingOf narn:turin ;
            rdfs:comment "Daughter of Húrin, sister of Túrin. Cursed by Glaurung with amnesia."@en ;
            rdfs:label "Nienor"@en ,
                       "Nienor Níniel"@en .


###  http://purl.org/narn/nienorDeath
narn:nienorDeath rdf:type owl:NamedIndividual ,
                          nev:Death ;
                 nev:causedBy narn:turinKillsGlaurung ;
                 nev:hasSubject narn:nienor ;
                 nev:occursAt narn:brethil ;
                 nev:precedes narn:turinDeath ;
                 rdfs:comment "Nienor, her memory restored, realises she has unknowingly married her own brother and throws herself into the river Teiglin."@en ;
                 rdfs:label "Death of Nienor"@en .


###  http://purl.org/narn/nirnaeth
narn:nirnaeth rdf:type owl:NamedIndividual ,
                       nev:Battle ,
                       nev:War ;
              nev:hasAgent meo:morgoth ;
              nev:hasTemporalExtent narn:tirNirnaeth ;
              nev:involvesCharacter meo:morgoth ,
                                    narn:hurin ;
              nev:occursAt narn:beleriand ;
              nev:precedes narn:hurinCapture ;
              rdfs:comment "The catastrophic fifth battle of Beleriand in which the armies of Elves and Men were defeated by Morgoth."@en ;
              rdfs:label "Battle of Unnumbered Tears"@en ,
                         "Nirnaeth Arnoediad"@en .


###  http://purl.org/narn/resolutionNarn
narn:resolutionNarn rdf:type owl:NamedIndividual ,
                             npl:Resolution ;
                    npl:correspondsToEvent narn:turinDeath ;
                    rdfs:label "Resolution: death of Túrin and Nienor"@en .


###  http://purl.org/narn/risingNarn
narn:risingNarn rdf:type owl:NamedIndividual ,
                         npl:RisingAction ;
                npl:correspondsToEvent narn:turinExile ;
                npl:precedes narn:climaxNarn ;
                rdfs:label "Rising action: Túrin's exile and wandering"@en .


###  http://purl.org/narn/thingol
narn:thingol rdf:type owl:NamedIndividual ,
                      fo:Male ,
                      meo:Elda ;
             fo:isMarriedTo narn:melian ;
             loc:isLordOf narn:doriath ;
             rdfs:comment "King of Doriath. Exiled Túrin after the death of Saeros."@en ;
             rdfs:label "Elwë"@en ,
                        "Thingol"@en .


###  http://purl.org/narn/tirFallNargothrond
narn:tirFallNargothrond rdf:type owl:NamedIndividual ,
                                 nti:TimeInterval ;
                        nti:before narn:tirTurinDeath ;
                        nti:hasBeginning 496 ;
                        nti:hasEnd 496 ;
                        rdfs:label "Fall of Nargothrond"@en .


###  http://purl.org/narn/tirHurinCaptivity
narn:tirHurinCaptivity rdf:type owl:NamedIndividual ,
                                nti:TimeInterval ;
                       nti:contains narn:tirTurinYouth ;
                       nti:hasBeginning 472 ;
                       nti:hasEnd 499 ;
                       rdfs:label "Húrin's captivity"@en .


###  http://purl.org/narn/tirNargothrond
narn:tirNargothrond rdf:type owl:NamedIndividual ,
                             nti:TimeInterval ;
                    nti:before narn:tirFallNargothrond ;
                    nti:hasBeginning 490 ;
                    nti:hasEnd 496 ;
                    rdfs:label "Túrin's time in Nargothrond"@en .


###  http://purl.org/narn/tirNirnaeth
narn:tirNirnaeth rdf:type owl:NamedIndividual ,
                          nti:TimeInterval ;
                 nti:before narn:tirHurinCaptivity ;
                 nti:hasBeginning 472 ;
                 nti:hasEnd 472 ;
                 rdfs:label "time of Nirnaeth Arnoediad"@en .


###  http://purl.org/narn/tirTurinDeath
narn:tirTurinDeath rdf:type owl:NamedIndividual ,
                            nti:TimeInterval ;
                   nti:hasBeginning 499 ;
                   nti:hasEnd 499 ;
                   rdfs:label "Túrin's death"@en .


###  http://purl.org/narn/tirTurinExile
narn:tirTurinExile rdf:type owl:NamedIndividual ,
                            nti:TimeInterval ;
                   nti:before narn:tirNargothrond ;
                   nti:hasBeginning 484 ;
                   nti:hasEnd 490 ;
                   rdfs:label "Túrin's exile and wandering"@en .


###  http://purl.org/narn/tirTurinYouth
narn:tirTurinYouth rdf:type owl:NamedIndividual ,
                            nti:TimeInterval ;
                   nti:before narn:tirTurinExile ;
                   nti:hasBeginning 473 ;
                   nti:hasEnd 484 ;
                   rdfs:label "Túrin's youth in Doriath"@en .


###  http://purl.org/narn/turin
narn:turin rdf:type owl:NamedIndividual ,
                    fo:Male ,
                    meo:Adan ;
           fo:isASiblingOf narn:nienor ;
           fo:isASonOf narn:hurin ,
                       narn:morwen ;
           loc:isEnemyOf narn:glaurung ;
           loc:isFriendOf narn:beleg ;
           loc:isMemberOf narn:houseOfHadorKingdom ,
                          narn:nargothrondFellowship ;
           loc:isProtégeOf narn:beleg ;
           loc:isVassalOf narn:thingol ;
           rdfs:comment "Protagonist of the Narn. Son of Húrin, bearer of the cursed black sword Gurthang."@en ;
           rdfs:label "Túrin"@en ,
                      "Túrin Turambar"@en .


###  http://purl.org/narn/turinArrivalDoriath
narn:turinArrivalDoriath rdf:type owl:NamedIndividual ,
                                  nev:Journey ;
                         nev:hasArrivalPlace narn:menegroth ;
                         nev:hasDeparturePlace narn:dorLomin ;
                         nev:hasTemporalExtent narn:tirTurinYouth ;
                         nev:involvesCharacter narn:turin ;
                         rdfs:comment "Túrin is brought to Doriath and fostered by Thingol."@en ;
                         rdfs:label "Túrin's arrival in Doriath"@en .


###  http://purl.org/narn/turinDeath
narn:turinDeath rdf:type owl:NamedIndividual ,
                         nev:Death ;
                nev:causedBy narn:nienorDeath ;
                nev:hasSubject narn:turin ;
                nev:hasTemporalExtent narn:tirTurinDeath ;
                nev:occursAt narn:brethil ;
                rdfs:comment "Túrin, learning of Nienor's fate, commands his black sword Gurthang to slay him. The sword obeys."@en ;
                rdfs:label "Death of Túrin"@en .


###  http://purl.org/narn/turinExile
narn:turinExile rdf:type owl:NamedIndividual ,
                         nev:Exile ;
                nev:hasSubject narn:turin ;
                nev:hasTemporalExtent narn:tirTurinExile ;
                nev:occursAt narn:doriath ;
                nev:precedes narn:belegDeath ;
                rdfs:comment "Túrin flees Doriath after the death of Saeros, fearing Thingol's judgment."@en ;
                rdfs:label "Túrin's exile from Doriath"@en .


###  http://purl.org/narn/turinKillsBelegAction
narn:turinKillsBelegAction rdf:type owl:NamedIndividual ,
                                    nac:UnintentionalAction ,
                                    nac:ViolentAction ;
                           nac:hasAgent narn:turin ;
                           nac:hasInstrument narn:gurthang ;
                           nac:hasPatient narn:beleg ;
                           nac:hasResult narn:belegDeath ;
                           nev:occursAt narn:dimbar ;
                           rdfs:comment "Túrin, startled awake in darkness, mistakes Beleg for an enemy and slays him. An unintentional violent act."@en ;
                           rdfs:label "Túrin kills Beleg (accidental)"@en .


###  http://purl.org/narn/turinKillsGlaurung
narn:turinKillsGlaurung rdf:type owl:NamedIndividual ,
                                 nev:Death ;
                        nev:hasAgent narn:turin ;
                        nev:hasSubject narn:glaurung ;
                        nev:hasTemporalExtent narn:tirTurinDeath ;
                        nev:occursAt narn:brethil ;
                        nev:precedes narn:nienorDeath ;
                        rdfs:comment "Túrin stabs Glaurung from beneath at the ravine of Cabed-en-Aras. As the dragon dies, Nienor remembers who she is."@en ;
                        rdfs:label "Túrin slays Glaurung"@en .


###  http://purl.org/narn/turinSuicide
narn:turinSuicide rdf:type owl:NamedIndividual ,
                           nac:IntentionalAction ,
                           nac:ViolentAction ;
                  nac:hasAgent narn:turin ;
                  nac:hasInstrument narn:gurthang ;
                  nac:hasPatient narn:turin ;
                  nac:hasPurpose narn:turinDeath ;
                  nev:occursAt narn:brethil ;
                  rdfs:comment "Túrin commands Gurthang to slay him. An intentional, physical, and violent action directed at himself."@en ;
                  rdfs:label "Túrin's suicide"@en .


#################################################################
#    Annotations
